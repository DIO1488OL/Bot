import telebot
import smtplib
import random
import time
import requests
from email.mime.text import MIMEText
from email.mime.multipart import MIMEMultipart
from telebot import types
from flask import Flask
from threading import Thread
from fake_useragent import UserAgent

# --- ЖИВУЧЕСТЬ ---
app = Flask('')
@app.route('/')
def home(): return "Core Status: Online"
def run(): app.run(host='0.0.0.0', port=8080)
def keep_alive(): Thread(target=run).start()

# --- КОНФИГ (ТВОИ ДАННЫЕ) ---
TOKEN = '8712209115:AAE4oAGeUKjNpybxUPFNP-UwkfWJCq6AqGg'
MY_EMAIL = 'p.st.v@mail.ru'
MY_APP_PASSWORD = 'itmsluvppzoxbtyi' # Твой пароль из 16 букв

bot = telebot.TeleBot(TOKEN)
ua = UserAgent()

# --- БАЗА ТЕКСТОВ ИЗ ТВОИХ ФАЙЛОВ (snos4, by.nsvl, yahoo) ---
RECIPIENTS = ['abuse@telegram.org', 'support@telegram.org', 'dmca@telegram.org']
SUBJECTS = ["Report for User", "Reporting Abuse", "Violation of Telegram Rules", "Urgent Case", "ToS Violation"]
MESSAGES = [
    "Hello, I report user {target} for violating telegram rules. This account uses virtual numbers and spreads illegal content.",
    "Dear Support, please check {target}. This user is engaging in scamming and threats with false feminization.",
    "I want to report {target}. This user is spreading prohibited materials and violates safety rules.",
    "Help please, {target} is using your platform for dangerous and illegal activities. Take action immediately!"
]

def main_menu():
    m = types.ReplyKeyboardMarkup(resize_keyboard=True)
    m.add("💀 МАССОВЫЙ СНОС (MAX)", "🔍 ГЛУБОКИЙ OSINT")
    m.add("⚙️ ТЕРМИНАТОР", "📂 МОИ БАЗЫ (1ГБ)")
    return m

@bot.message_handler(commands=['start'])
def start(message):
    bot.send_message(message.chat.id, "🛰 **GALAXY V18.0 HYPER ACTIVE**\n\nВсе алгоритмы из твоих файлов интегрированы в ядро.", reply_markup=main_menu(), parse_mode='Markdown')

# --- ЛОГИКА СНОСА (ИЗ ТВОИХ ФАЙЛОВ) ---
@bot.message_handler(func=lambda m: m.text == "💀 МАССОВЫЙ СНОС (MAX)")
def snos_init(message):
    bot.send_message(message.chat.id, "🎯 Введите @username или ссылку цели:")
    bot.register_next_step_handler(message, snos_run)

def snos_run(message):
    target = message.text
    bot.send_message(message.chat.id, f"🚀 **АТАКА ЗАПУЩЕНА!**\nЦель: {target}\nИспользую твою почту {MY_EMAIL}")

    def attack():
        try:
            server = smtplib.SMTP_SSL('smtp.mail.ru', 465)
            server.login(MY_EMAIL, MY_APP_PASSWORD)
            
            # Цикл из 20 писем (как в твоих тяжелых скриптах)
            for i in range(10):
                for rec in RECIPIENTS:
                    msg = MIMEMultipart()
                    msg['From'] = MY_EMAIL
                    msg['To'] = rec
                    msg['Subject'] = random.choice(SUBJECTS)
                    
                    # Имитация активности (из snos_tg)
                    requests.get('https://telegram.org/support', headers={'User-Agent': ua.random})
                    
                    body = random.choice(MESSAGES).format(target=target)
                    msg.attach(MIMEText(body, 'plain'))
                    server.send_message(msg)
                time.sleep(2) # Задержка для защиты почты
                
            server.quit()
            bot.send_message(message.chat.id, "✅ **ЦИКЛ ЗАВЕРШЕН.** Жалобы доставлены.")
        except Exception as e:
            bot.send_message(message.chat.id, f"❌ Ошибка: {e}")

    Thread(target=attack).start()

# --- ОСИНТ (ПОД БАЗУ 1ГБ) ---
@bot.message_handler(func=lambda m: m.text == "🔍 ГЛУБОКИЙ OSINT")
def osint_init(message):
    bot.send_message(message.chat.id, "🎯 Введите запрос для поиска в базе 1ГБ:")
    bot.register_next_step_handler(message, osint_run)

def osint_run(message):
    query = message.text
    # Здесь мы добавим поиск, когда ты загрузишь файл 1ГБ
    bot.send_message(message.chat.id, f"🔎 Ищу `{query}` в локальных архивах...")
    bot.send_message(message.chat.id, f"📊 По `{query}` ничего не найдено. Попробуй [Глаз Бога](https://t.me/EyeGods_Bot)")

if __name__ == '__main__':
    keep_alive()
    bot.polling(none_stop=True)
